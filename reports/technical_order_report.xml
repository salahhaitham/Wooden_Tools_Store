<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="technical_order_report_action"
            model="ir.actions.report">

        <field name="name">Technical Order</field>
        <field name="model">technical.order</field>

        <field name="binding_model_id" ref="model_technical_order"/>
        <field name="binding_type">report</field>

        <field name="report_type">qweb-pdf</field>
        <field name="report_name">Wooden_Tools_Store.technical_order_report_template</field>

    </record>




<template id="technical_order_report_template">

<t t-call="web.html_container">

<t t-call="web.external_layout">

<div class="page">

<t t-foreach="docs" t-as="o">

<h2>Technical Order</h2>

<table class="table table-sm table-bordered">

<tr>
    <td><strong>Sequence</strong></td>
    <td><span t-field="o.name"/></td>
</tr>

<tr>
    <td><strong>Request Name</strong></td>
    <td><span t-field="o.request_name"/></td>
</tr>

<tr>
    <td><strong>Requested By</strong></td>
    <td><span t-field="o.requested_by"/></td>
</tr>

<tr>
    <td><strong>Customer</strong></td>
    <td><span t-field="o.custormer_id"/></td>
</tr>

<tr>
    <td><strong>Start Date</strong></td>
    <td><span t-field="o.start_date"/></td>
</tr>

<tr>
    <td><strong>End Date</strong></td>
    <td><span t-field="o.end_date"/></td>
</tr>

<tr>
    <td><strong>Status</strong></td>
    <td><span t-field="o.state"/></td>
</tr>

<tr t-if="o.state == 'reject'">
    <td><strong>Rejection Reason</strong></td>
    <td><span t-field="o.rejection_reason"/></td>
</tr>

<tr>
    <td><strong>Total</strong></td>
    <td><span t-field="o.total"/></td>
</tr>

</table>

<br/>

<h3>Order Lines</h3>

<table class="table table-bordered">

<thead>

<tr>
    <th>#</th>
    <th>Product</th>
    <th>Description</th>
    <th>Qty</th>
    <th>Price</th>
    <th>Total</th>
</tr>

</thead>

<tbody>

<tr t-foreach="o.technical_order_ids" t-as="line">

<td>
    <span t-field="line.sequence"/>
</td>

<td>
    <span t-field="line.product_id"/>
</td>

<td>
    <span t-field="line.description"/>
</td>

<td>
    <span t-field="line.quantity"/>
</td>

<td>
    <span t-field="line.price"/>
</td>

<td>
    <span t-field="line.total_price"/>
</td>

</tr>

</tbody>

</table>

</t>

</div>

</t>

</t>

</template>

</odoo>
