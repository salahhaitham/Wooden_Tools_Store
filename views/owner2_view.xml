<odoo>
     <record id="owner_tree_view" model="ir.ui.view">
         <field name="name">owner </field>
         <field name="model">owner</field>
         <field name="arch" type="xml">
              <list>
                  <field name="name"/>
                  <field name="phone"/>
                  <field name="address"/>




              </list>
         </field>

     </record>




<record id="owner_form" model="ir.ui.view">
    <field name="name">owner form</field>
    <field name="model">owner</field>
    <field name="arch" type="xml">
        <form >
            <sheet>
               <div class="oe_title">
    <label for="name"/>
    <h1>
        <field name="name"/>
    </h1>
</div>
                <group>

                        <field name="phone"/>

                        <field name="address"/>

                </group>
                 <group>





                </group>

            </sheet>
        </form>
    </field>
</record>

    <record id="owner_action" model="ir.actions.act_window">
        <field name="name">owner </field>
        <field name="res_model">owner</field>
            <field name="view_mode">list,form</field>

    </record>
<menuitem id="owner_view_id" name="owner" parent="base_menu_root" action="owner_action"/>
</odoo>